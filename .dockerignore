# --- VIGIBYTE VERSION CONTROL IGNORE POLICY ---
# Purpose: Ensures that local environment secrets, dependency folders, 
# and IDE-specific configurations are not pushed to the repository.

# --- DEPENDENCIES ---
# Always ignore node_modules; they should be freshly installed via 'npm install'
node_modules/

# --- LOGS & DEBUGGING ---
# Clears environment-specific error logs to keep the repo clean
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- BUILD OUTPUTS ---
# Prevents production-ready artifacts from polluting the source code history
dist/
build/
coverage/

# --- LOCAL ENVIRONMENT SECRETS ---
# CRITICAL: Prevents Supabase, Roboflow, and JWT keys from leaking online
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- IDE & EDITOR CONFIGURATIONS ---
# Specific settings for VS Code and JetBrains editors
.vscode/
.idea/
*.swp
*.swo
*~

# --- SYSTEM SPECIFIC FILES ---
# Junk files generated by macOS and Windows
.DS_Store
Thumbs.db

# --- LINTING & TESTING ---
# Cache files for ESLint to maintain performance locally
.eslintcache