# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anonymous_key_here

# Optional: Supabase Service Role Key (for backend operations)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI/ML Configuration
VITE_FACE_DETECTION_MIN_CONFIDENCE=0.6
VITE_FACE_DETECTION_DISTANCE_THRESHOLD=0.5

# Application Configuration
VITE_APP_NAME=VigiByte
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_2FA=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_AUDIT_LOGGING=true

# Security Configuration
VITE_PASSWORD_MIN_LENGTH=8
VITE_SESSION_TIMEOUT=3600000
VITE_LOGIN_RATE_LIMIT=5

# Development Configuration
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Docker Configuration (if using Docker)
PORT=5173
NODE_ENV=production
