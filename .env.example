# --- VIGIBYTE ENVIRONMENT TEMPLATE (.env.example) ---
# Purpose: This file serves as a blueprint for developers setting up VigiByte.
# INSTRUCTIONS: Copy this file to a new file named '.env' and fill in your actual credentials.

# --- SUPABASE CLOUD CONFIGURATION ---
# Obtain these from your Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- CRYPTOGRAPHIC SECURITY ---
# A random string used for signing JWT-style session tokens. 
# Recommended: Generate a 64-character random hex string.
VITE_JWT_SECRET=your-jwt-secret-key-here

# --- APPLICATION IDENTITY ---
VITE_APP_NAME=VigiByte

# --- DATABASE CONNECTIVITY (OPTIONAL) ---
# Required only if you are running a self-hosted PostgreSQL instance via Docker Compose.
DATABASE_URL=postgresql://vigibyte_user:vigibyte_secure_password_123@vigibyte-db:5432/vigibyte_db

# --- AI BACKEND CONFIGURATION ---
# URL for the Python FastAPI recognition engine.
# Use the 'Local' URL for development or the 'Render' URL for production deployment.
VITE_BACKEND_URL=http://your-project.hf.space